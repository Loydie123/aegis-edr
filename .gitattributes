# ==============================================================================
# AEGIS EDR - Git Attributes Configurations
# ==============================================================================

# Global line endings normalization to Unix Line Feed (LF)
* text=auto eol=lf

# ------------------------------------------------------------------------------
# 1. Custom Language Syntax Diff Parsers
# ------------------------------------------------------------------------------
*.go text diff=go
*.c text diff=c
*.h text diff=c
*.cpp text diff=cpp
*.hpp text diff=cpp
*.proto text

# ------------------------------------------------------------------------------
# 2. Configuration & Documentation
# ------------------------------------------------------------------------------
*.yaml text
*.yml text
*.json text
*.md text
Makefile text

# ------------------------------------------------------------------------------
# 3. Binary Files Exclusions
# ------------------------------------------------------------------------------
# Prevent Git from attempting to merge or normalize line endings in binary files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.wasm binary
*.db binary
